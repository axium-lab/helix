
# ── OpenAI ───────────────────────────────────────────────────────────────────
# Generate at https://platform.openai.com/api-keys
HELIX_OPENAI_API_KEY=

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
# All four required for Azure tests to run.
HELIX_AZURE_API_KEY=
HELIX_AZURE_ENDPOINT=https://<your-resource>.openai.azure.com/
HELIX_AZURE_API_VERSION=2024-10-01-preview
HELIX_AZURE_DEPLOYMENT=

# ── Custom (OpenAI-compatible — Mistral, Groq, Ollama, etc.) ─────────────────
# BASE_URL and API_KEY required; MODEL optional (defaults to "default").
HELIX_CUSTOM_API_KEY=
HELIX_CUSTOM_BASE_URL=
HELIX_CUSTOM_MODEL=
