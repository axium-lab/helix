{
  "name": "@axium-lab/helix",
  "version": "0.1.0",
  "description": "Unified TypeScript interface for multiple LLM providers (OpenAI, Azure, Google AI Studio)",
  "license": "UNLICENSED",
  "type": "module",
  "author": "pierslabs",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/axium-lab/helix.git"
  },
  "publishConfig": {
    "@axium-lab:registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist",
    "dev": "tsx watch --env-file=.env tests/manual.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration"
  },
  "dependencies": {
    "@google/genai": "^2.6.0",
    "openai": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=22"
  }
}
